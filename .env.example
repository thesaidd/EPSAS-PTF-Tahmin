PROJECT_NAME=EPİAŞ PTF Forecasting MVP
APP_VERSION=0.1.0
ENVIRONMENT=development

POSTGRES_USER=pepias
POSTGRES_PASSWORD=pepias
POSTGRES_DB=pepias
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://pepias:pepias@db:5432/pepias
MLFLOW_DATABASE=mlflow

API_PORT=8000
STREAMLIT_PORT=8501
MLFLOW_PORT=5000
API_URL=http://api:8000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://pepias:pepias@db:5432/mlflow

EPIAS_BASE_URL=https://seffaflik.epias.com.tr
EPIAS_AUTH_URL=https://giris.epias.com.tr

# EPİAŞ Şeffaflık Platformu credentials
# Put your EPİAŞ login email here. Do not commit real credentials.
EPIAS_USERNAME=

# Put your EPİAŞ password here. Do not commit real credentials.
EPIAS_PASSWORD=
EPIAS_REQUEST_TIMEOUT=30
EPIAS_MAX_RETRIES=3
EPIAS_PTF_ENDPOINT=/electricity-service/v1/markets/dam/data/mcp

# Optional daily pipeline scheduler. Disabled unless the scheduler Compose profile is used.
DAILY_PIPELINE_ENABLED=false
DAILY_PIPELINE_RUN_TIME_LOCAL=13:00
DAILY_PIPELINE_TIMEZONE=Europe/Istanbul
